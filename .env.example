# Delivery location used when checking availability.
DELIVERY_ZIP=98101

# How often the scheduler checks each active product, in minutes.
CHECK_INTERVAL_MINUTES=30

# Run the browser headless (recommended true in containers/servers).
HEADLESS=true

# Per-check navigation timeout, in seconds.
REQUEST_TIMEOUT_SECONDS=45

# SQLAlchemy database URL.
DATABASE_URL=sqlite:///./costco_restock.db

# Start the background scheduler when the app boots.
ENABLE_SCHEDULER=true

# Email alerts (Resend). Optional: leave blank to disable email.
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# SMS alerts (Twilio). Optional: leave blank to disable SMS.
# Authenticate with either the auth token or an API key pair (SID + secret).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_FROM_NUMBER=
# One or more recipients in E.164 format, comma-separated (shared by all SMS channels).
ALERT_SMS_TO=

# SMS alerts (TextBelt). Pay-as-you-go; no phone number or registration needed.
# Buy a key at https://textbelt.com and the recipients above will be texted.
TEXTBELT_API_KEY=

# Include the product URL in SMS. Off by default; some gateways block links from
# unverified senders. Enable after verifying your sender.
SMS_INCLUDE_URL=false
