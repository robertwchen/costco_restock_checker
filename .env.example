# Delivery location used when checking availability.
DELIVERY_ZIP=98101

# How often the scheduler checks each active product, in minutes.
CHECK_INTERVAL_MINUTES=30

# Run the browser headless (recommended true in containers/servers).
HEADLESS=true

# Per-check navigation timeout, in seconds.
REQUEST_TIMEOUT_SECONDS=45

# SQLAlchemy database URL.
DATABASE_URL=sqlite:///./costco_restock.db

# Start the background scheduler when the app boots.
ENABLE_SCHEDULER=true

# Email alerts (Resend). Optional: leave blank to disable email.
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# SMS alerts (Twilio). Optional: leave blank to disable SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_SMS_TO=
